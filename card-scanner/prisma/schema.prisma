model Contact {
  id                 String   @id @default(cuid())

  fullName           String?
  jobTitle           String?
  company            String?

  mobileNumbers      String[]
  telephoneNumbers   String[]
  emails             String[]

  website            String?
  address            String?
  companyLocation    String?

  linkedin           String?

  rawNotes           String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
